# direnv 統合設定ファイル
# https://direnv.net/ をインストール後、`direnv allow` を一度実行すること。
# このファイルはリポジトリ管理対象。シークレットは記載しない。
# .env / .env.shared はコミット対象外だが、.envrc は安全にコミット可能。

# 共有設定（コミット済み）→ プロジェクト共通の非シークレット設定を読み込む
dotenv_if_exists .env.shared

# ローカル上書き設定（.gitignore 済み）→ 個人の認証情報・アカウント情報を読み込む
dotenv_if_exists .env

# Terraform 用ブリッジ変数:
# .env の SNOWFLAKE_ACCOUNT を TF_VAR_ 経由で Terraform に渡す。
# これにより .env は SNOWFLAKE_ACCOUNT の 1 行のみを管理すれば十分になる。
if [ -n "${SNOWFLAKE_ACCOUNT:-}" ]; then
  export TF_VAR_SNOWFLAKE_ACCOUNT="${SNOWFLAKE_ACCOUNT}"
fi

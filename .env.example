# ------------------------------------------------------------
# アプリ起動用の環境変数テンプレート
# このファイルを .env にコピーして値を入力してください
# .env は Git 管理対象外です（コミットしない）
# ------------------------------------------------------------

# 必須: 実行環境（dev または prod）
APP_ENV=dev

# ------------------------------------------------------------
# Terraform / HCP Cloud
# ------------------------------------------------------------
# 必須: HCP Terraform 組織名
HCP_TF_ORGANIZATION=zappyzed100
# 必須: dev ワークスペース名
HCP_TF_WORKSPACE_DEV=dev-real-time-logistics-strategy-engine-distilled-mip-1m-01ms
# 必須: prod ワークスペース名
HCP_TF_WORKSPACE_PROD=prod-real-time-logistics-strategy-engine-distilled-mip-1m-01ms

# ------------------------------------------------------------
# Snowflake 共通
# ------------------------------------------------------------
# 必須: Snowflake アカウント識別子（例: XXXXXXX-XXXXXXXX）
SNOWFLAKE_ACCOUNT=YOUR-ACCOUNT-ID

# 任意: Bronze 層の初期スキーマ（通常は RAW_DATA）
SNOWFLAKE_BRONZE_SCHEMA=RAW_DATA

# ------------------------------------------------------------
# データベース名（環境別）
# ------------------------------------------------------------
# 必須: dev 用 DB 名
DEV_BRONZE_DB=DEV_BRONZE_DB
DEV_SILVER_DB=DEV_SILVER_DB
DEV_GOLD_DB=DEV_GOLD_DB

# 必須: prod 用 DB 名
PROD_BRONZE_DB=PROD_BRONZE_DB
PROD_SILVER_DB=PROD_SILVER_DB
PROD_GOLD_DB=PROD_GOLD_DB

# ------------------------------------------------------------
# ローダーユーザー（src/infrastructure/snowflake_loader.py）
# Bronze 層への書き込み用
# ------------------------------------------------------------
# 必須: dev ローダー接続情報
DEV_LOADER_USER=DEV_LOADER_USER
DEV_LOADER_ROLE=DEV_LOADER_ROLE
DEV_LOADER_WH=DEV_LOADER_WH
DEV_LOADER_USER_RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# 必須: prod ローダー接続情報
PROD_LOADER_USER=PROD_LOADER_USER
PROD_LOADER_ROLE=PROD_LOADER_ROLE
PROD_LOADER_WH=PROD_LOADER_WH
PROD_LOADER_USER_RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# 任意: 共通ローダー鍵を使う場合（環境別鍵の代替）
# SNOWFLAKE_LOADER_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# SNOWFLAKE_LOADER_PRIVATE_KEY_PASSPHRASE=your-passphrase

# ------------------------------------------------------------
# dbt 実行ユーザー（enterprise_data_pipeline/profiles.yml, run_dbt.py）
# ------------------------------------------------------------
# 必須: dev dbt 接続情報
DEV_DBT_USER=DEV_DBT_USER
DEV_DBT_ROLE=DEV_DBT_ROLE
DEV_DBT_WH=DEV_DBT_WH
DEV_DBT_USER_RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# 必須: prod dbt 接続情報
PROD_DBT_USER=PROD_DBT_USER
PROD_DBT_ROLE=PROD_DBT_ROLE
PROD_DBT_WH=PROD_DBT_WH
PROD_DBT_USER_RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# 任意: 秘密鍵パスフレーズ（鍵にパスフレーズがある場合のみ）
# SNOWFLAKE_DBT_PRIVATE_KEY_PASSPHRASE=your-passphrase

# ------------------------------------------------------------
# Streamlit ユーザー（src/streamlit/app.py）
# Gold 層の参照用
# ------------------------------------------------------------
# 必須: dev Streamlit 接続情報
DEV_STREAMLIT_USER=DEV_STREAMLIT_USER
DEV_STREAMLIT_ROLE=DEV_STREAMLIT_ROLE
DEV_STREAMLIT_WH=DEV_STREAMLIT_WH
DEV_STREAMLIT_USER_RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# 必須: prod Streamlit 接続情報
PROD_STREAMLIT_USER=PROD_STREAMLIT_USER
PROD_STREAMLIT_ROLE=PROD_STREAMLIT_ROLE
PROD_STREAMLIT_WH=PROD_STREAMLIT_WH
PROD_STREAMLIT_USER_RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ------------------------------------------------------------
# Terraform メモ
# TF_VAR_* は可能な限り HCP Terraform Workspace Variables を使用
# 共有する .env に機密情報を直接保持しない
# ------------------------------------------------------------

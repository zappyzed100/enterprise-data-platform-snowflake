#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
ENV_FILE="${PROJECT_ROOT}/.env"
load_local_env() {
  if [[ -f "${ENV_FILE}" ]]; then
    set -a
    # shellcheck disable=SC1090
    . "${ENV_FILE}"
    set +a
  fi
}

require_env_value() {
  local key="$1"
  local value="$2"

  if [[ -z "${value}" ]]; then
    echo "[tf] ${key} must be set in the current shell or ${ENV_FILE}." >&2
    exit 1
  fi
}

normalize_tf_token() {
  if [[ -z "${TF_TOKEN_app_terraform_io:-}" ]]; then
    if [[ -n "${HCP_TERRAFORM_TOKEN:-}" ]]; then
      export TF_TOKEN_app_terraform_io="${HCP_TERRAFORM_TOKEN}"
    fi
  fi

  require_env_value "TF_TOKEN_app_terraform_io (or HCP_TERRAFORM_TOKEN)" "${TF_TOKEN_app_terraform_io:-}"
}

normalize_provider_overrides() {
  if [[ -n "${SNOWFLAKE_USER:-}" ]]; then
    export TF_VAR_snowflake_user="${SNOWFLAKE_USER}"
  fi

  if [[ -n "${SNOWFLAKE_PRIVATE_KEY:-}" ]]; then
    export TF_VAR_snowflake_private_key="${SNOWFLAKE_PRIVATE_KEY}"
  fi

  if [[ -n "${SNOWFLAKE_ROLE:-}" ]]; then
    export TF_VAR_SNOWFLAKE_ROLE="${SNOWFLAKE_ROLE}"
  fi
}

load_local_env
normalize_tf_token

APP_ENV_LOWER="${APP_ENV:-dev}"
case "${APP_ENV_LOWER}" in
  dev|prod)
    ;;
  *)
    echo "[tf] APP_ENV must be 'dev' or 'prod' (current: ${APP_ENV_LOWER})" >&2
    exit 1
    ;;
esac

if [[ "${APP_ENV_LOWER}" == "prod" ]]; then
  ci_value="${CI:-}"
  gha_value="${GITHUB_ACTIONS:-}"
  if [[ "${ci_value,,}" != "true" && "${gha_value,,}" != "true" ]]; then
    echo "[tf] APP_ENV=prod は CI 実行でのみ許可されています。ローカルでは APP_ENV=dev を使用してください。" >&2
    exit 1
  fi
fi

export TF_VAR_app_env="${APP_ENV_LOWER}"
normalize_provider_overrides

BACKEND_CONFIG_FILE="${SCRIPT_DIR}/backend.${APP_ENV_LOWER}.hcl"
if [[ ! -f "${BACKEND_CONFIG_FILE}" ]]; then
  echo "[tf] backend config not found: ${BACKEND_CONFIG_FILE}" >&2
  exit 1
fi

ensure_init() {
  terraform -chdir="${SCRIPT_DIR}" init \
    -reconfigure \
    -backend-config="${BACKEND_CONFIG_FILE}" >/dev/null
}

cmd="${1:-}"
if [[ -z "${cmd}" ]]; then
  echo "Usage: ./terraform/tf <init|plan|apply|...> [args...]" >&2
  exit 1
fi
shift || true

case "${cmd}" in
  init)
    terraform -chdir="${SCRIPT_DIR}" init \
      -reconfigure \
      -backend-config="${BACKEND_CONFIG_FILE}" "$@"
    ;;
  *)
    ensure_init
    terraform -chdir="${SCRIPT_DIR}" "${cmd}" "$@"
    ;;
esac
